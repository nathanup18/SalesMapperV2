generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model House {
  id        String      @id @default(cuid())
  address   String?
  latitude  Float
  longitude Float
  events    DoorEvent[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([latitude, longitude])
  @@map("houses")
}

// Append-only event log.
// type = "CREATE" for new placements, "EDIT" for edits via the edit modal.
// Latest event per house = current visible state on the map.
model DoorEvent {
  id            String   @id @default(cuid())
  houseId       String
  house         House    @relation(fields: [houseId], references: [id], onDelete: Cascade)
  type          String   @default("CREATE") // "CREATE" | "EDIT"
  status        String   // NOT_HOME | NOT_INTERESTED | SOLD | NOT_VISITED
  notes         String?
  createdByName String
  createdAt     DateTime @default(now())

  @@index([houseId])
  @@index([status])
  @@index([createdAt])
  @@map("door_events")
}
